extends ../t-header

block logo
  img(src="@img/t-theme/logo.svg" alt="logo")

block input
  div.header__input.input-header(data-component='header-input')
    div.input-header__field
      div.input-header__icon
        +icon('t-chat')
      input.input-header__input.header-input(type="text")
      p.input-header__label.header-input
        span.input-header__label_first Что Вас интересует? Вы можете найти товар или задать интересующий вопрос
    div.input-header__tags
      - const inputTags = ['Доставка и оплата', 'Нужна помощь с выбором', 'Что покупают чаще?', 'Индивидуальный заказ', 'Контакты', 'Наши услуги', 'Наши преимущества']
      each tag in inputTags
        button.input-header__tag= tag

block actions
  div.header__actions
    a.header__action(href="#")
      +icon('t-person')
    a.header__action(href="#")
      +icon('t-cart')

block hamburger
  div.hamburger(data-component='hamburger')
    button.hamburger__button.hamburger__button_closed(data-hamburger-button)
      +icon('s-menu')
    button.hamburger__button.hamburger__button_opened(data-hamburger-button)
      span Закрыть
      +icon('s-close')

block info
  -
    const categories = [
      { label: 'ФУтляры', href: '#', icon: 't-pouch' },
      { label: 'Мешочки Ювелирные', href: '#', icon: 't-case' },
      { label: 'перчатки Ювелирные', href: '#', icon: 't-glove' },
      { label: 'Салфетки', href: '#', icon: 't-napkin' },
      { label: 'Упаковка', href: '#', icon: 't-package' },
      { label: 'Аксессуары', href: '#', icon: 't-accessories' },
    ];
  div.header__categories
    each category in categories
      a.header__category(href=category.href)
        +icon(category.icon)
        span= category.label